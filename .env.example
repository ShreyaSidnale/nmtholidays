# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Strong random string used to sign Payload tokens. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change_this_to_a_long_random_string

# Database connection.
# - Leave BLANK for local development -> uses a zero-config SQLite file (nmt.db).
# - For production, set a Postgres URL (Neon/Supabase). When it starts with
#   "postgres" the app automatically uses the Postgres adapter.
# Example (Neon): postgres://user:pass@ep-xxx.region.aws.neon.tech/nmt?sslmode=require
DATABASE_URI=

# Public site URL (used for SEO canonical URLs, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Resend API key for sending contact/enquiry notification emails.
# Without it, submissions are still saved to the admin (just no email is sent).
RESEND_API_KEY=
# Inbox that receives enquiry notifications.
ENQUIRY_NOTIFY_EMAIL=

# Google Analytics 4 measurement id (e.g. G-XXXXXXX). Optional.
NEXT_PUBLIC_GA_ID=

# Demo mode: serve static demo content on the PUBLIC site with no database.
# - true  -> always demo (great for a prototype)
# - false -> always use the real database
# - unset -> auto: demo on Vercel only when DATABASE_URI is not set
# The /admin panel always uses the real database regardless of this setting.
DEMO_MODE=

# Vercel Blob storage token for admin media uploads (required on Vercel so
# uploaded images persist — the serverless filesystem is ephemeral).
# Created automatically when you add a Blob store to the project in Vercel.
# Leave blank locally (uploads go to disk).
BLOB_READ_WRITE_TOKEN=
